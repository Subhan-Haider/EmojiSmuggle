{
  "manifest_version": 3,
  "name": "Emoji Smuggle",
  "version": "1.0.0",
  "description": "Hide secret messages inside innocent emojis using invisible steganography.",
  "permissions": [
    "contextMenus",
    "storage",
    "clipboardWrite",
    "clipboardRead"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "app_icon.png"
  },
  "icons": {
    "16": "app_icon.png",
    "48": "app_icon.png",
    "128": "app_icon.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
